{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CocoScript",
  "scopeName": "source.cocoscript",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#builtins" },
    { "include": "#include" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#selfvar" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.cocoscript",
          "match": "\\*//.*$"
        },
        {
          "name": "comment.line.double-dash.cocoscript",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cocoscript",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cocoscript",
              "match": "\\\\[nrt\\\\\"']"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.cocoscript",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.cocoscript",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cocoscript",
          "match": "\\b(if|then|else|elseif|end|while|do|for|return|break)\\b"
        },
        {
          "name": "keyword.declaration.cocoscript",
          "match": "\\b(func|local|class)\\b"
        },
        {
          "name": "keyword.operator.logical.cocoscript",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.cocoscript",
          "match": "\\b(true|false|nil)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.cocoscript",
          "match": "\\b(print|input|exit|halt|exec|len|tostring|toint)\\b"
        }
      ]
    },
    "include": {
      "patterns": [
        {
          "name": "keyword.control.import.cocoscript",
          "match": "#include"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.cocoscript",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.assignment.cocoscript",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.cocoscript",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.concat.cocoscript",
          "match": "\\.\\."
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.cocoscript",
          "match": "(?<=func\\s)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "entity.name.class.cocoscript",
          "match": "(?<=class\\s)[a-zA-Z_][a-zA-Z0-9_]*"
        }
      ]
    },
    "selfvar": {
      "patterns": [
        {
          "name": "variable.language.self.cocoscript",
          "match": "\\bself\\b"
        }
      ]
    }
  }
}
