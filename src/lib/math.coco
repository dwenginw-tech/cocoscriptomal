func abs(x)
  if x < 0 then
    return 0 - x
  end
  return x
end

func min(a, b)
  if a < b then
    return a
  end
  return b
end

func max(a, b)
  if a > b then
    return a
  end
  return b
end

func clamp(x, lo, hi)
  if x < lo then
    return lo
  elseif x > hi then
    return hi
  end
  return x
end

func sign(x)
  if x > 0 then
    return 1
  elseif x < 0 then
    return 0 - 1
  end
  return 0
end

func lerp(a, b, t)
  return a + (b - a) * t
end
